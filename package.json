{
  "name": "webmux",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "portless --script dev:raw",
    "build": "bun run --filter '@webmux/*' build",
    "test": "bun test packages --timeout 15000",
    "test:unit": "bun test packages --path-ignore-patterns '**/*.integration.test.ts'",
    "test:integration": "bun test integration.test.ts --timeout 15000",
    "test:e2e": "playwright test",
    "test:coverage": "bun test packages --timeout 15000 --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run --filter '@webmux/*' typecheck",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test",
    "check:full": "bun run check && bun run test:e2e",
    "clean": "bun run --filter '@webmux/*' clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "portless": "^0.12.0",
    "prettier": "^3.8.1"
  }
}
